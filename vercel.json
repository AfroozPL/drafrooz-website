{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/cleanup-pending",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 4 * * *"
    }
  ]
}
